{
  "name": "vite-plugin-git-semver",
  "version": "1.0.0",
  "description": "Vite plugin for Git-based version management with semver support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vite",
    "plugin",
    "git",
    "version",
    "semver",
    "git-describe"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish",
    "lint": "oxlint . --fix",
    "lint:check": "oxlint .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tayne3/vite-plugin-git-semver"
  },
  "homepage": "https://github.com/tayne3/vite-plugin-git-semver#readme"
}
